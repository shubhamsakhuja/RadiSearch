# =============================================================================
# RadiSearch — Environment Configuration
# =============================================================================
# Rename this file from "_env" to ".env" before running the app.
# NEVER commit .env to git — it contains passwords and secret keys.
# =============================================================================


# ── PostgreSQL database ───────────────────────────────────────────────────────
# Leave blank when USE_PKL_DATA=true (not needed for local testing)
POSTGRES_HOST=
POSTGRES_DATABASE=
POSTGRES_USERNAME=
POSTGRES_PASSWORD=


# ── Data source ───────────────────────────────────────────────────────────────
# true  = load from embedding_meta.pkl (local testing, no database needed)
# false = connect to PostgreSQL above (production default)
USE_PKL_DATA=true


# ── Azure AD SSO ──────────────────────────────────────────────────────────────
# Leave as placeholders when DEV_MODE=true (not needed for local testing)
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=your-secret-value-from-azure
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_ALLOWED_DOMAIN=hospital.com


# ── Flask session key ─────────────────────────────────────────────────────────
# Generate a real key with:
#   python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=


# ── Dev mode ──────────────────────────────────────────────────────────────────
# true  = skip Azure AD login, auto-login as "Dev User" (local testing ONLY)
# false = require Microsoft login (production)
# WARNING: NEVER set true on a shared or internet-facing server
DEV_MODE=true


# =============================================================================
# AWS CONFIGURATION
# =============================================================================
# How to get your credentials:
#   1. AWS Console -> top-right menu -> Security credentials
#   2. Access keys -> Create access key -> choose "Local code"
#   3. Copy the two values below
#
# BEFORE FIRST USE - enable models in AWS Console (one-time, ~2 min):
#   AWS Console -> Bedrock -> Model access -> Request access for:
#     Anthropic Claude 3 Haiku   (for LLM -- USE_BEDROCK=true)
#   Without this you will get AccessDeniedException on every call.
# =============================================================================

AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=


# ── Bedrock LLM (replaces Ollama) ─────────────────────────────────────────────
# true  = LLM queries go to AWS Bedrock Claude (~$0.002/query)
# false = LLM queries go to local Ollama (free, default)
#
# Start here for testing -- cheapest and easiest to validate.
# $100 free credits = ~50,000 queries before you pay anything.
USE_BEDROCK=true
BEDROCK_LLM_MODEL=au.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_MAX_TOKENS=1024


# ── Bedrock Embeddings (replaces local sentence-transformers) ─────────────────
# true  = embeddings built with Amazon Titan V2 (~$0.02/1M tokens)
# false = embeddings built locally with all-MiniLM-L6-v2 (free, default)
#
# WARNING: Keep false during testing. Switching requires deleting chroma_db/
# and rebuilding the entire index. Only enable long-term.
USE_BEDROCK_EMBED=false
BEDROCK_EMBED_MODEL=amazon.titan-embed-text-v2:0


# ── S3 data source (optional) ─────────────────────────────────────────────────
# true  = download embedding_meta.pkl from S3 at startup
# false = use local embedding_meta.pkl file (default)
#
# Only needed when deploying to EC2. Leave false for local development.
USE_S3=false
AWS_S3_BUCKET=
AWS_S3_PKL_KEY=embedding_meta.pkl
